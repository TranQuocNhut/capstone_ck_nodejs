<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <title>Welcome to Capstone!</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      line-height: 1.6;
      background-color: #f4f4f4;
